# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecobench

# OpenAI Configuration (optional - will use TinyLlama if not set)
OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
LOG_LEVEL=INFO
DEBUG=false
SECRET_KEY=your-secret-key-here

# LLM Configuration
LLM_PROVIDER=tinyllama  # Options: tinyllama, openai, mock
TINYLLAMA_MODEL_PATH=./models/tinyllama
EMBEDDING_DIMENSION=1536

# File Storage
DATA_DIR=./data
MAX_FILE_SIZE=50MB

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
