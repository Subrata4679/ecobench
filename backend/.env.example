# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ecobench

# LLM Configuration
LLM_PROVIDER=openai  # Options: mock, tinyllama, openai
OPENAI_API_KEY=your_openai_api_key_here
TINYLLAMA_MODEL_PATH=/path/to/tinyllama/model

# Web Scraping Configuration
SCRAPING_ENABLED=true
SCRAPING_DELAY_SECONDS=2
MAX_CONCURRENT_SCRAPING_JOBS=3

# Chatbot Configuration
CHATBOT_ENABLED=true
MAX_CHAT_HISTORY=50
CHAT_SESSION_TIMEOUT_HOURS=24

# Application Configuration
SECRET_KEY=your_secret_key_here
DEBUG=false
LOG_LEVEL=INFO

# File Storage Configuration
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=./uploads

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000

# Redis Configuration (for Celery)
REDIS_URL=redis://localhost:6379/0

# Test Configuration
TEST_DATABASE_URL=postgresql://testuser:testpass@localhost:5432/testdb
